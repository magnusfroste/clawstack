# ── ClawStack ──────────────────────────────────────────────────────────────
# Domain for the admin portal (e.g. clawstack.yourdomain.com)
BASE_DOMAIN=clawstack.yourdomain.com

# Email for Let's Encrypt TLS certificates
CADDY_EMAIL=you@yourdomain.com

# Admin portal login
ADMIN_USER=admin
ADMIN_PASS=changeme

# OpenClaw image to use for new instances
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Timezone for containers
TZ=Europe/Stockholm

# ── Paperclip ──────────────────────────────────────────────────────────────
# Domain for the Paperclip orchestrator (e.g. boss.yourdomain.com)
PAPERCLIP_DOMAIN=boss.yourdomain.com

# Random secret — generate with: openssl rand -hex 32
PAPERCLIP_SECRETS_KEY=

# Anthropic API key for Paperclip's built-in Claude access (optional)
ANTHROPIC_API_KEY=

# ── Private LLM for Claude CLI (optional) ─────────────────────────────────
#ANTHROPIC_BASE_URL=http://your-llm-host
#ANTHROPIC_AUTH_TOKEN=your-token
#ANTHROPIC_API_KEY=
#CLAUDE_DEFAULT_MODEL=your-model
