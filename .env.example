# Your domain — admin portal will be served here
BASE_DOMAIN=clawstack.yourdomain.com

# Email for Let's Encrypt certificates
CADDY_EMAIL=you@yourdomain.com

# Admin login for the portal
ADMIN_USER=admin
ADMIN_PASS=changeme

# OpenClaw image version (update to get new releases)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.3.24

# Timezone
TZ=Europe/Stockholm
