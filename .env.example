# Your domain — admin portal will be served here
BASE_DOMAIN=clawstack.yourdomain.com

# Email for Let's Encrypt certificates
CADDY_EMAIL=you@yourdomain.com

# Admin login for the portal
ADMIN_USER=admin
ADMIN_PASS=changeme

# OpenClaw image version (update to get new releases)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.3.24

# Timezone
TZ=Europe/Stockholm

# Anthropic API key — used by Claude Code CLI inside the Paperclip container
# Leave empty if using a private LLM via CLAUDE_BASE_URL below
ANTHROPIC_API_KEY=sk-ant-...

# Private LLM for Claude Code CLI (optional — leave blank to use Anthropic directly)
CLAUDE_BASE_URL=http://api.autoversio.ai
CLAUDE_AUTH_TOKEN=sk-...
CLAUDE_MODEL=autoversio
